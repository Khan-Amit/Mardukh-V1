<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://android.com"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/control_layout"> <!-- Linked to your 3rd PNG Asset -->

    <!-- Top Status Overlay Banner -->
    <LinearLayout
        android:id="@+id/statusHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CC111111"
        android:orientation="horizontal"
        android:padding="20dp"
        android:layout_alignParentTop="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CORE SHIELD:"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvLiveEngineStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="STANDBY"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Administrative Operations Dashboard Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_margin="16dp"
        android:background="#E6050505"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- START SYSTEM OPERATION BUTTON -->
        <Button
            android:id="@+id/btnStartEngine"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#00FF66"
            android:text="START FILTRATION PIPELINE"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- STOP SYSTEM OPERATION BUTTON -->
        <Button
            android:id="@+id/btnStopEngine"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#FF3333"
            android:text="STOP SOCKET CORES"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- LAUNCH LIVE DIAGNOSTICS REPORT BUTTON -->
        <Button
            android:id="@+id/btnViewTelemetry"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:backgroundTint="#FFD700"
            android:text="OPEN INSTRUMENTATION REPORT"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</RelativeLayout>
